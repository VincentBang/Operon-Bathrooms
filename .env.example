NEXT_PUBLIC_SITE_URL=https://www.operonbathrooms.com.au
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional local/staging admin and notification settings.
# Do not commit real tokens, emails or API keys.
OPERON_BATHROOMS_ADMIN_TOKEN=
OPERON_BATHROOMS_ADMIN_EMAIL=
OPERON_BATHROOMS_FROM_EMAIL=
OPERON_BATHROOMS_REPLY_TO_EMAIL=
OPERON_BATHROOMS_SITE_URL=http://localhost:3000
OPERON_BATHROOMS_NOTIFICATION_MODE=preview
RESEND_API_KEY=

# Optional local/staging Design Studio route preview.
# This enables route rendering only; discovery remains hidden unless the
# discovery variable is explicitly set to "public".
NEXT_PUBLIC_ENABLE_BATHROOM_DESIGN_STUDIO=
# Optional discovery mode. Leave blank for hidden controlled-pilot discovery.
# Use "public" only after a later public-discovery approval.
NEXT_PUBLIC_BATHROOM_DESIGN_STUDIO_DISCOVERY=
